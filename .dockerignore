# Version control
.git/
.gitignore

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Test suite (not needed at runtime)
tests/
pytest.ini
.pytest_cache/

# Local secrets — never bake these into the image
.env
.env.*

# IDE / OS noise
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore
